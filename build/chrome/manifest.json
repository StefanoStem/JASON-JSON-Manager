{
  "manifest_version": 3,
  "name": "JASON (JSON Manager)",
  "version": "1.2.0",
  "description": "Local-first JSON sidebar to capture, compare, and manage JSON payloads",
  "content_security_policy": {
    "extension_pages": "default-src 'self'; connect-src 'none'; script-src 'self'; object-src 'self'"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "Open JASON"
  },
  "permissions": ["sidePanel", "storage", "tabs", "activeTab", "scripting"],
  "background": {
    "service_worker": "background.js"
  }
}
